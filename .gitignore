# -----------------------------------------------------------------------------
# OS Specific
# -----------------------------------------------------------------------------
.DS_Store           # macOS
.Trashes            # macOS
._*                 # macOS resource forks
Thumbs.db           # Windows
ehthumbs.db         # Windows
Desktop.ini         # Windows
$RECYCLE.BIN/       # Windows Recycle Bin
*.bak               # Backup files
*.swp               # Vim swap files
*.swo               # Vim swap files
*~                  # Emacs backup files

# -----------------------------------------------------------------------------
# IDE and Editor Specific
# -----------------------------------------------------------------------------
# Visual Studio Code
.vscode/            # VS Code settings and extensions
.history/           # VS Code Local History

# IntelliJ IDEA / Android Studio
.idea/              # IntelliJ project files
*.iml               # IntelliJ module files
*.ipr               # IntelliJ project files
*.iws               # IntelliJ workspace files
out/                # IntelliJ output directory

# Eclipse
.project            # Eclipse project file
.classpath          # Eclipse classpath file
.settings/          # Eclipse project settings
*.launch            # Eclipse launch configurations
.buildpath          # Eclipse build path

# Sublime Text
*.sublime-project
*.sublime-workspace

# Atom
.atom/

# Vim
.vim/

# -----------------------------------------------------------------------------
# Build Artifacts and Dependency Directories (Common)
# -----------------------------------------------------------------------------
# Node.js
node_modules/       # Node.js dependencies
npm-debug.log*      # npm debug log
yarn-debug.log*     # Yarn debug log
yarn-error.log*     # Yarn error log
.pnp/               # Yarn PnP
.pnp.js             # Yarn PnP
.pnp.cjs            # Yarn PnP
dist/               # Distribution directory
build/              # Build output directory
tmp/                # Temporary files

# Python
__pycache__/        # Python compiled bytecode
*.pyc               # Python compiled bytecode
.venv/              # Python virtual environment
venv/               # Python virtual environment
env/                # Python virtual environment
.env                # Environment variables (often sensitive)
*.egg-info/         # Python egg info
.pytest_cache/      # Pytest cache

# Java
target/             # Maven build directory
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
bin/                # Compiled classes (often for Eclipse)
*.class             # Compiled Java class files
*.jar               # Java archive files
*.war               # Web application archive files
*.ear               # Enterprise application archive files
.gradle/            # Gradle files
# build/ already defined at line 59

# Ruby
.bundle/            # Bundler directory
vendor/bundle/      # Bundler dependencies
log/*.log           # Log files
# tmp/ already defined at line 60

# Go
# bin/ already defined at line 82
pkg/                # Compiled packages

# PHP
vendor/             # Composer dependencies

# C/C++
*.o                 # Object files
*.a                 # Archive files
*.so                # Shared libraries
*.lo                # Libtool object files
*.la                # Libtool archive files
*.dll               # Dynamic link libraries
*.exe               # Executables
*.out               # Output files

# -----------------------------------------------------------------------------
# Logs and Temporary Files
# -----------------------------------------------------------------------------
*.log               # Log files
*.tmp               # Temporary files
temp/               # Temporary directory

